SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local development: USE_SQLITE=true (default when DEBUG=true)
USE_SQLITE=True

# Production (Render): set DATABASE_URL and USE_SQLITE=false
DATABASE_URL=
USE_SQLITE=False

# Cloudinary (required on Render; optional locally — leave blank to use media/ folder)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
